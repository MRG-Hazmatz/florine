{
  "schemaVersion": 1,
  "unitId": "a1.1/unit-04-age-family",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Choose the correct form of avoir: « Elle ___ deux frères. »",
      "options": [
        {
          "id": "a",
          "text": "a"
        },
        {
          "id": "b",
          "text": "as"
        },
        {
          "id": "c",
          "text": "ai"
        },
        {
          "id": "d",
          "text": "ont"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "il/elle a. Full set: j'ai, tu as, il/elle a, nous avons, vous avez, ils/elles ont."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "How do you say \"I am 13 years old\" in French?",
      "options": [
        {
          "id": "a",
          "text": "Je suis treize ans."
        },
        {
          "id": "b",
          "text": "J'ai treize ans."
        },
        {
          "id": "c",
          "text": "J'ai treize."
        }
      ],
      "correct": [
        "b"
      ],
      "explanation": "French uses avoir for age: « j'ai treize ans » (literally 'I have thirteen years'). Never être, and don't drop « ans »."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Complete the conversation with the right form of avoir.",
      "inputMode": "typed",
      "template": "Tu {{b1}} quel âge ? — J'{{b2}} dix ans.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "as"
          ]
        },
        {
          "id": "b2",
          "accept": [
            "ai"
          ]
        }
      ],
      "explanation": "tu as, j'ai."
    },
