  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « Comment ça s'écrit ? » mean?",
      "options": [
        {
          "id": "a",
          "text": "How is it spelled?"
        },
        {
          "id": "b",
          "text": "What's your name?"
        },
        {
          "id": "c",
          "text": "How are you?"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« Comment ça s'écrit ? » = How is it spelled / written?"
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Complete: « ___ est votre nom ? » (nom is masculine)",
      "options": [
        {
          "id": "a",
          "text": "Quel"
        },
        {
          "id": "b",
          "text": "Quelle"
        },
        {
          "id": "c",
          "text": "Qui"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "quel agrees with the noun; nom is masculine → quel."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "The accent on « é » is called:",
      "options": [
        {
          "id": "a",
          "text": "un accent aigu"
        },
        {
          "id": "b",
          "text": "un accent grave"
        },
        {
          "id": "c",
          "text": "une cédille"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "é = e accent aigu. (è = grave, ç = cédille)"
    },
