    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: what does the brother look like?",
      "audio": "audio/a1.1/unit-09-describing/listen-1.mp3",
      "transcript": "Mon frère est grand et il a les cheveux bruns.",
      "options": [
        {
          "id": "a",
          "text": "Tall, with brown hair"
        },
        {
          "id": "b",
          "text": "Short, with blond hair"
        },
        {
          "id": "c",
          "text": "Young, with brown hair"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« grand » (tall) + « les cheveux bruns » (brown hair)."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read about Léa and answer both questions.",
