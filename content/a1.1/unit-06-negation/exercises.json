  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "How do you say \"I don't speak French\" correctly?",
      "options": [
        {
          "id": "a",
          "text": "Je ne parle pas français."
        },
        {
          "id": "b",
          "text": "Je parle pas français."
        },
        {
          "id": "c",
          "text": "Je ne parle français."
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Negation needs BOTH pieces around the verb: ne parle pas."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Make the sentence negative (he does NOT speak English).",
      "inputMode": "typed",
      "template": "Il {{b1}} parle {{b2}} anglais.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "ne"
          ]
        },
        {
          "id": "b2",
          "accept": [
            "pas"
          ]
        }
      ],
      "explanation": "ne … pas wraps the verb: il ne parle pas."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Complete: « Je ___ aime pas le café. »",
      "options": [
        {
          "id": "a",
          "text": "n'"
        },
        {
          "id": "b",
          "text": "ne"
        },
        {
          "id": "c",
          "text": "pas"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "ne becomes n' before a vowel: je n'aime pas."
    },
