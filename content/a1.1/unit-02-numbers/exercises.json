  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Which French number is 80?",
      "options": [
        {
          "id": "a",
          "text": "quatre-vingts"
        },
        {
          "id": "b",
          "text": "soixante-dix"
        },
        {
          "id": "c",
          "text": "quatre-vingt-dix"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "80 = quatre-vingts (literally 4 × 20). 70 = soixante-dix, 90 = quatre-vingt-dix."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« soixante-dix » is which number?",
      "options": [
        {
          "id": "a",
          "text": "70"
        },
        {
          "id": "b",
          "text": "60"
        },
        {
          "id": "c",
          "text": "80"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "soixante-dix = 60 + 10 = 70."
    },
