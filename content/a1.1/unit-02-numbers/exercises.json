{
  "schemaVersion": 1,
  "unitId": "a1.1/unit-02-numbers",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Which French word means \"seven\"?",
      "options": [
        { "id": "a", "text": "cinq" },
        { "id": "b", "text": "six" },
        { "id": "c", "text": "sept" },
        { "id": "d", "text": "huit" }
      ],
      "correct": ["c"],
      "explanation": "sept = seven. cinq = 5, six = 6, huit = 8."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Complete the sequence.",
      "inputMode": "typed",
      "template": "un, deux, {{b1}}, quatre",
      "blanks": [{ "id": "b1", "accept": ["trois"] }],
      "explanation": "un (1), deux (2), trois (3), quatre (4)."
    },
    {
      "id": "ex-ro-1",
      "type": "reorder",
      "skill": "writing",
      "prompt": "Put these numbers in counting order (smallest first).",
      "tokens": [
        { "id": "t1", "text": "deux" },
        { "id": "t2", "text": "quatre" },
        { "id": "t3", "text": "six" }
      ],
      "correctOrder": ["t1", "t2", "t3"]
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each numeral to the French word.",
      "pairs": [
        { "id": "p1", "left": "4", "right": "quatre" },
        { "id": "p2", "left": "6", "right": "six" },
        { "id": "p3", "left": "9", "right": "neuf" },
        { "id": "p4", "left": "10", "right": "dix" }
      ]
    },
    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen and choose the number you hear.",
      "audio": "audio/a1.1/unit-02-numbers/listen-1.mp3",
      "transcript": "cinq",
      "options": [
        { "id": "a", "text": "quatre (4)" },
        { "id": "b", "text": "cinq (5)" },
        { "id": "c", "text": "six (6)" }
      ],
      "correct": ["b"]
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read the exchange and answer.",
      "passageFr": "— Tu as quel âge ?\n— J'ai dix ans.",
      "passageEn": "— How old are you?\n— I am ten years old.",
      "questions": [
        {
          "id": "q1",
          "prompt": "How old is the person?",
          "options": [
            { "id": "a", "text": "Two" },
            { "id": "b", "text": "Eight" },
            { "id": "c", "text": "Ten" }
          ],
          "correct": ["c"]
        }
      ]
    }
  ]
}
