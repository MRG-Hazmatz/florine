{
  "schemaVersion": 1,
  "unitId": "a1.1/unit-02-numbers",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Which number comes right after « huit »?",
      "options": [
        { "id": "a", "text": "sept" },
        { "id": "b", "text": "neuf" },
        { "id": "c", "text": "dix" },
        { "id": "d", "text": "six" }
      ],
      "correct": ["b"],
      "explanation": "sept (7), huit (8), neuf (9), dix (10)."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Complete the sequence with the two missing numbers (in words).",
      "inputMode": "typed",
      "template": "six, sept, {{b1}}, {{b2}}, dix",
      "blanks": [
        { "id": "b1", "accept": ["huit"] },
        { "id": "b2", "accept": ["neuf"] }
      ],
      "explanation": "six, sept, huit, neuf, dix."
    },
    {
      "id": "ex-ro-1",
      "type": "reorder",
      "skill": "writing",
      "prompt": "Put these numbers in DESCENDING order (biggest first).",
      "tokens": [
        { "id": "t1", "text": "un" },
        { "id": "t2", "text": "trois" },
        { "id": "t3", "text": "cinq" }
      ],
      "correctOrder": ["t3", "t2", "t1"],
      "explanation": "Biggest first: cinq (5), trois (3), un (1)."
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each numeral to the French word.",
      "pairs": [
        { "id": "p1", "left": "0", "right": "zéro" },
        { "id": "p2", "left": "7", "right": "sept" },
        { "id": "p3", "left": "8", "right": "huit" },
        { "id": "p4", "left": "9", "right": "neuf" }
      ]
    },
    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen to the sentence. How old is the person?",
      "audio": "audio/a1.1/unit-02-numbers/listen-1.mp3",
      "transcript": "J'ai sept ans.",
      "options": [
        { "id": "a", "text": "6" },
        { "id": "b", "text": "7" },
        { "id": "c", "text": "8" }
      ],
      "correct": ["b"],
      "explanation": "« J'ai sept ans » = I am seven years old."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read about Tom and answer both questions.",
      "passageFr": "Bonjour ! Je m'appelle Tom. J'ai huit ans. J'ai deux frères.",
      "passageEn": "Hello! My name is Tom. I am eight years old. I have two brothers.",
      "questions": [
        {
          "id": "q1",
          "prompt": "How old is Tom?",
          "options": [
            { "id": "a", "text": "6" },
            { "id": "b", "text": "8" },
            { "id": "c", "text": "10" }
          ],
          "correct": ["b"]
        },
        {
          "id": "q2",
          "prompt": "How many brothers does he have?",
          "options": [
            { "id": "a", "text": "1" },
            { "id": "b", "text": "2" },
            { "id": "c", "text": "3" }
          ],
          "correct": ["b"]
        }
      ]
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Write the number in words.",
      "inputMode": "typed",
      "template": "4 = {{b1}}",
      "blanks": [{ "id": "b1", "accept": ["quatre"] }],
      "explanation": "4 = quatre."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Trois cafés, s'il vous plaît. » How many coffees are ordered?",
      "options": [
        { "id": "a", "text": "2" },
        { "id": "b", "text": "3" },
        { "id": "c", "text": "4" }
      ],
      "correct": ["b"],
      "explanation": "trois = 3."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Which number is « seize »?",
      "options": [
        { "id": "a", "text": "6" },
        { "id": "b", "text": "16" },
        { "id": "c", "text": "60" }
      ],
      "correct": ["b"],
      "explanation": "seize = 16. (six = 6, soixante = 60)"
    },
    {
      "id": "ex-fb-3",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Write the number in words.",
      "inputMode": "typed",
      "template": "40 = {{b1}}",
      "blanks": [{ "id": "b1", "accept": ["quarante"] }],
      "explanation": "40 = quarante."
    },
    {
      "id": "ex-mc-4",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What number is « vingt-trois »?",
      "options": [
        { "id": "a", "text": "13" },
        { "id": "b", "text": "23" },
        { "id": "c", "text": "32" }
      ],
      "correct": ["b"],
      "explanation": "vingt (20) + trois (3) = vingt-trois (23)."
    }
  ]
}
