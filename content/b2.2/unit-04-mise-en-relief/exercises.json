{
  "schemaVersion": 1,
  "unitId": "b2.2/unit-04-mise-en-relief",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Spotlight the object: « ___ nous voulons, c'est un vrai débat. »",
      "options": [
        {
          "id": "a",
          "text": "Ce que"
        },
        {
          "id": "b",
          "text": "Ce qui"
        },
        {
          "id": "c",
          "text": "Ce dont"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Vouloir quelque chose (direct object) → ce que… c'est…"
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "De-verb spotlight: « ___ le pays a besoin, c'est de courage. »",
      "options": [
        {
          "id": "a",
          "text": "Ce dont"
        },
        {
          "id": "b",
          "text": "Ce que"
        },
        {
          "id": "c",
          "text": "Ce qui"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Avoir besoin DE → ce dont… c'est…"
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Subject focus.",
      "inputMode": "dropdown",
      "template": "{{b1}} me choque, c'est le silence des médias.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "Ce qui"
          ],
          "options": [
            "Ce qui",
            "Ce que",
            "C'est qui"
          ]
        }
      ],
      "explanation": "The thing IS the subject of choquer → ce qui… c'est…"
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Great or tall?",
      "inputMode": "dropdown",
      "template": "Victor Hugo était un {{b1}} : tout un pays l'a pleuré.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "grand homme"
          ],
          "options": [
            "grand homme",
            "homme grand"
          ]
        }
      ],
      "explanation": "Before the noun = figurative: un grand homme = a great man."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Un ancien ministre » means…",
      "options": [
        {
          "id": "a",
          "text": "a former minister"
        },
        {
          "id": "b",
          "text": "a very old minister"
        },
        {
          "id": "c",
          "text": "a minister of antiques"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Before the noun, ancien = former. After (un bâtiment ancien) = old."
    },
    {
      "id": "ex-fb-3",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "As for… (two words)",
      "inputMode": "typed",
      "template": "{{b1}} à moi, je préfère m'abstenir.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "Quant"
          ]
        }
      ],
      "explanation": "Quant à = as for: quant à moi…"
    },
