{
  "schemaVersion": 1,
  "unitId": "b2.2/unit-02-taste-figures",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Ce dessert est un nuage. » — which figure of style?",
      "options": [
        {
          "id": "a",
          "text": "une métaphore"
        },
        {
          "id": "b",
          "text": "une comparaison"
        },
        {
          "id": "c",
          "text": "une négation"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "No bridge-word (comme) — the image IS the thing: a metaphor."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Ce gâteau fond comme la neige au soleil. » — which figure?",
      "options": [
        {
          "id": "a",
          "text": "une comparaison"
        },
        {
          "id": "b",
          "text": "une métaphore"
        },
        {
          "id": "c",
          "text": "une exagération sans image"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "The bridge-word comme is present → comparison (simile)."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Generality — which article?",
      "inputMode": "dropdown",
      "template": "J'adore {{b1}} chocolat noir.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "le"
          ],
          "options": [
            "le",
            "du",
            "un"
          ]
        }
      ],
      "explanation": "Loves and generalities take the definite article: j'adore le chocolat."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "An unmeasured amount — which article?",
      "inputMode": "dropdown",
      "template": "Tu veux {{b1}} sauce avec le poisson ?",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "de la"
          ],
          "options": [
            "de la",
            "la",
            "une"
          ]
        }
      ],
      "explanation": "Some, unmeasured → partitive: de la sauce."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "The negation trap: « Je ne veux pas ___ sucre. »",
      "options": [
        {
          "id": "a",
          "text": "de"
        },
        {
          "id": "b",
          "text": "du"
        },
        {
          "id": "c",
          "text": "le"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "After pas, the partitive collapses to de: pas de sucre."
    },
    {
      "id": "ex-fb-3",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Build the comparison (one word).",
      "inputMode": "typed",
