{
  "schemaVersion": 1,
  "unitId": "b1.2/unit-06-pronouns-narration",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "« Tu as donné la lettre à Paul ? — Oui, je ___ ai donnée. »",
      "options": [
        {
          "id": "a",
          "text": "la lui"
        },
        {
          "id": "b",
          "text": "lui la"
        },
        {
          "id": "c",
          "text": "le lui"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "le/la/les come BEFORE lui/leur: je la lui ai donnée (la = la lettre, hence donnée agrees)."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "« Ces indemnités, il doit ___ payer. » (them, to me)",
      "options": [
        {
          "id": "a",
          "text": "me les"
        },
        {
          "id": "b",
          "text": "les me"
        },
        {
          "id": "c",
          "text": "me leur"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "me/te/nous/vous come BEFORE le/la/les: il doit me les payer."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "\"I had told him so!\" — stack the pronouns.",
      "inputMode": "dropdown",
      "template": "Je {{b1}} avais bien dit !",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "le lui"
          ],
          "options": [
            "le lui",
            "lui le",
            "la lui"
          ]
        }
      ],
      "explanation": "Neutral le (= that idea) before lui: je le lui avais bien dit."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Shift the time marker into a past narrative.",
      "inputMode": "dropdown",
      "template": "Dans son récit, « hier » devient {{b1}}.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "la veille"
          ],
          "options": [
            "la veille",
            "le lendemain",
            "ce jour-là"
          ]
        }
      ],
      "explanation": "hier → la veille (the day before), just like in reported speech."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "In a past narrative, « demain » becomes…",
      "options": [
        {
          "id": "a",
          "text": "le lendemain"
        },
        {
          "id": "b",
          "text": "la veille"
        },
        {
          "id": "c",
          "text": "aujourd'hui"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "demain → le lendemain (the next day); après-demain → le surlendemain."
    },
    {
      "id": "ex-fb-3",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Complete the time marker (one word).",
      "inputMode": "typed",
      "template": "Trois jours plus {{b1}}, le procès a commencé.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "tard"
          ]
        }
      ],
      "explanation": "dans trois jours → trois jours plus tard in a past narrative."
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each story-time word to its English meaning.",
      "pairs": [
        {
          "id": "p1",
          "left": "la veille",
          "right": "the day before"
        },
        {
          "id": "p2",
