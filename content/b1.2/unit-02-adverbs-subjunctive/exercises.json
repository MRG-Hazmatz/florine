  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the adverb of « heureux »?",
      "options": [
        {
          "id": "a",
          "text": "heureusement"
        },
        {
          "id": "b",
          "text": "heureuxment"
        },
        {
          "id": "c",
          "text": "heureument"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "General rule: feminine adjective + -ment → heureuse + ment = heureusement."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the adverb of « évident »?",
      "options": [
        {
          "id": "a",
          "text": "évidemment"
        },
        {
          "id": "b",
          "text": "évidentement"
        },
        {
          "id": "c",
          "text": "évidamment"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "-ent → -emment: évident → évidemment (pronounced \"a-ment\")."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Adverb of « courant » — watch the ending.",
