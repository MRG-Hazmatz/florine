    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Where does the adverb go in a compound tense?",
      "options": [
        {
          "id": "a",
          "text": "J'ai énormément aimé cette exposition."
        },
        {
          "id": "b",
          "text": "J'ai aimé énormément cette exposition."
        },
        {
          "id": "c",
          "text": "Énormément j'ai aimé cette exposition."
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Between the auxiliary and the participle: j'ai énormément aimé."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Spell the adverb of « fréquent ».",
