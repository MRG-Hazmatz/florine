    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen to the reviewer. What are they saying?",
      "audio": "audio/b1.2/unit-02-adverbs-subjunctive/listen-1.mp3",
      "transcript": "Franchement, c'est l'exposition la plus originale que je connaisse !",
      "options": [
        {
          "id": "a",
          "text": "It's the most original exhibition they know — high praise"
        },
        {
          "id": "b",
          "text": "It's frankly the most boring exhibition they've seen"
        },
        {
          "id": "c",
          "text": "They don't know if the exhibition is original"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« la plus originale que je connaisse » — superlative + subjunctive: the most original one I know."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read these two museum reviews and answer both questions.",
      "passageFr": "Léa ★★★★★ : « L'architecture vaut vraiment le détour. J'ai particulièrement aimé les grandes baies vitrées. »\nBoris ★★ : « Je suis un peu déçu. Les œuvres sont insuffisamment mises en valeur, et je n'ai rien vu qui soit vraiment original. »",
      "passageEn": "Léa ★★★★★: \"The architecture is really worth the trip. I particularly liked the big glass windows.\"\nBoris ★★: \"I'm a bit disappointed. The works aren't shown off well enough, and I didn't see anything really original.\"",
      "questions": [
        {
          "id": "q1",
          "prompt": "What did Léa particularly like?",
          "options": [
            {
              "id": "a",
              "text": "The big glass windows"
            },
            {
              "id": "b",
              "text": "The paintings"
            },
            {
              "id": "c",
              "text": "The gift shop"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "Why is Boris disappointed?",
          "options": [
            {
              "id": "a",
              "text": "The works are poorly displayed and nothing felt original"
            },
            {
              "id": "b",
              "text": "The museum was closed"
            },
            {
              "id": "c",
              "text": "The architecture was ugly"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-mc-4",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Why is « connaisse » in the subjunctive in « la plus originale que je connaisse »?",
      "options": [
        {
          "id": "a",
          "text": "After a superlative (la plus…), the relative takes the subjunctive"
        },
        {
          "id": "b",
          "text": "Connaître is always subjunctive"
        },
        {
          "id": "c",
          "text": "It's a spelling mistake"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Superlatives and restrictions (le seul, le premier, le plus…) push the relative into the subjunctive."
    },
