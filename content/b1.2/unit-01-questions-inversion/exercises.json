{
  "schemaVersion": 1,
  "unitId": "b1.2/unit-01-questions-inversion",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Which is the FORMAL (written) register for \"Do you like the cinema?\"",
      "options": [
        {
          "id": "a",
          "text": "Aimez-vous le cinéma ?"
        },
        {
          "id": "b",
          "text": "Vous aimez le cinéma ?"
        },
        {
          "id": "c",
          "text": "Est-ce que vous aimez le cinéma ?"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Inversion (verb–subject, hyphen) is the formal/journalistic register. Intonation is spoken; est-ce que is neutral."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Why is there a -t- in « Quel événement le 14 juillet célèbre-t-il ? »",
      "options": [
        {
          "id": "a",
          "text": "The verb ends in a vowel — the -t- makes it pronounceable before il"
        },
        {
          "id": "b",
          "text": "It marks the past tense"
        },
        {
          "id": "c",
          "text": "It is part of the verb célébrer"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "The euphonic -t-: célèbre + il would clash two vowels → célèbre-t-il."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Compound tense: only the auxiliary inverts.",
      "inputMode": "dropdown",
      "template": "Quel film {{b1}}-t-il préféré ?",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "a"
          ],
          "options": [
            "a",
            "est",
            "avait-il"
          ]
        }
      ],
      "explanation": "Passé composé: the auxiliary avoir inverts → Quel film a-t-il préféré ?"
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "The noun subject is repeated as a pronoun — which one?",
      "inputMode": "dropdown",
      "template": "Depuis quand les femmes ont-{{b1}} le droit de vote ?",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "elles"
          ],
          "options": [
            "elles",
            "ils",
            "elle"
          ]
        }
      ],
      "explanation": "Les femmes (feminine plural) is repeated as elles: les femmes ont-elles…"
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Turn « Vous avez commencé quand ? » into a formal inversion question.",
      "options": [
        {
          "id": "a",
          "text": "Quand avez-vous commencé ?"
        },
        {
          "id": "b",
          "text": "Quand vous avez commencé ?"
        },
        {
          "id": "c",
          "text": "Avez-quand vous commencé ?"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Question word first, then inverted auxiliary: Quand avez-vous commencé ?"
    },
    {
      "id": "ex-fb-3",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Insert the missing euphonic letter.",
      "inputMode": "typed",
