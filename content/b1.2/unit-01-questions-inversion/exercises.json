    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen to the interview exchange. What is the journalist asking?",
      "audio": "audio/b1.2/unit-01-questions-inversion/listen-1.mp3",
      "transcript": "Depuis quand habitez-vous à Paris ? — J'y habite depuis dix ans.",
      "options": [
        {
          "id": "a",
          "text": "How long the person has lived in Paris"
        },
        {
          "id": "b",
          "text": "Where the person wants to live"
        },
        {
          "id": "c",
          "text": "Why the person left Paris ten years ago"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« Depuis quand habitez-vous… ? » — since when / how long have you lived…? Answer: for ten years."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read this extract from a celebrity interview and answer both questions.",
      "passageFr": "— Quel prix votre film a-t-il remporté cette année ?\n— Le prix du meilleur acteur. Je ne m'y attendais pas du tout !\n— Vos parents étaient-ils inquiets quand vous avez choisi ce métier ?\n— Oui, beaucoup. Ils pensaient que c'était un coup de tête.",
      "passageEn": "— Which award did your film win this year?\n— Best actor. I wasn't expecting it at all!\n— Were your parents worried when you chose this profession?\n— Yes, very. They thought it was an impulsive decision.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What award did the film win?",
          "options": [
            {
              "id": "a",
              "text": "Best actor"
            },
            {
              "id": "b",
              "text": "Best film"
            },
            {
              "id": "c",
              "text": "Best director"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "How did the parents react to the career choice?",
          "options": [
            {
              "id": "a",
              "text": "They were very worried"
            },
            {
              "id": "b",
              "text": "They were delighted"
            },
            {
              "id": "c",
              "text": "They didn't care"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-mc-4",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Common trap: how do you say \"to ask a question\"?",
      "options": [
        {
          "id": "a",
          "text": "poser une question"
        },
        {
          "id": "b",
          "text": "demander une question"
        },
        {
          "id": "c",
          "text": "questionner une question"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Always poser une question — never « demander une question »."
    },
