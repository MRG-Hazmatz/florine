{
  "schemaVersion": 1,
  "unitId": "b1.2/unit-07-indefinites-negation",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What is the opposite of « partout »?",
      "options": [
        {
          "id": "a",
          "text": "nulle part"
        },
        {
          "id": "b",
          "text": "quelque part"
        },
        {
          "id": "c",
          "text": "chacun"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "partout = everywhere; nulle part = nowhere."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Complete: « ___ ne répondait au téléphone. »",
      "options": [
        {
          "id": "a",
          "text": "Personne"
        },
        {
          "id": "b",
          "text": "Rien"
        },
        {
          "id": "c",
          "text": "Quelqu'un"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "For people: personne ne… (Rien is for things; quelqu'un isn't negative.)"
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Some… others.",
      "inputMode": "dropdown",
      "template": "{{b1}} aiment la mer, d'autres préfèrent la montagne.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "Certains"
          ],
          "options": [
            "Certains",
            "Chacun",
            "Personne"
          ]
        }
      ],
      "explanation": "The pair certains… d'autres = some… others."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Negation with an infinitive — where do the parts go?",
      "inputMode": "dropdown",
      "template": "J'ai décidé de {{b1}} bouger.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "ne plus"
          ],
          "options": [
            "ne plus",
            "plus ne",
            "pas"
          ]
        }
      ],
      "explanation": "With an infinitive, BOTH negation words go before the verb: de ne plus bouger."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Je ne suis arrivé que deux heures plus tard. » means…",
      "options": [
        {
          "id": "a",
          "text": "I only arrived two hours later"
        },
        {
          "id": "b",
          "text": "I never arrived"
        },
        {
          "id": "c",
          "text": "I arrived two hours early"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Ne… que isn't a true negation — it means seulement (only)."
    },
    {
      "id": "ex-fb-3",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Neither… nor (one word).",
      "inputMode": "typed",
      "template": "Je n'aime {{b1}} la chaleur ni les moustiques.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "ni"
          ]
        }
      ],
      "explanation": "Ne… ni… ni: je n'aime ni la chaleur ni les moustiques."
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each indefinite to its English meaning.",
      "pairs": [
        {
          "id": "p1",
          "left": "chacun",
          "right": "each one"
        },
        {
          "id": "p2",
          "left": "quelque part",
          "right": "somewhere"
        },
        {
          "id": "p3",
          "left": "la plupart",
          "right": "most"
        },
        {
          "id": "p4",
          "left": "aucun",
          "right": "none"
        }
      ]
    },
    {
      "id": "ex-ro-1",
      "type": "reorder",
      "skill": "writing",
      "prompt": "Put the words in order: \"Nobody was answering the phone.\"",
      "tokens": [
        {
          "id": "t1",
          "text": "Personne"
        },
        {
          "id": "t2",
          "text": "ne"
        },
        {
          "id": "t3",
          "text": "répondait"
        },
        {
          "id": "t4",
          "text": "au"
        },
        {
          "id": "t5",
          "text": "téléphone"
        }
      ],
      "correctOrder": [
        "t1",
        "t2",
        "t3",
        "t4",
        "t5"
      ]
    },
    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen to the traveller's complaint. What went wrong?",
      "audio": "audio/b1.2/unit-07-indefinites-negation/listen-1.mp3",
      "transcript": "On n'a rien visité : il pleuvait partout et personne ne voulait sortir.",
      "options": [
        {
          "id": "a",
          "text": "They visited nothing — it rained everywhere and nobody wanted to go out"
        },
        {
          "id": "b",
          "text": "They visited everything despite the rain"
        },
        {
          "id": "c",
          "text": "Someone got lost during a visit"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "rien (nothing) + partout (everywhere) + personne (nobody) — a full indefinite disaster."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read Gilles's ruined-trip story and answer both questions.",
      "passageFr": "Le vol avait dix heures de retard et je n'avais pas pris le numéro de mes amis. Je ne savais où aller : rien ne pouvait se faire avant le matin. Je n'ai réussi à les joindre que deux heures plus tard. Après ça, plus aucun voyage lointain, plus jamais !",
      "passageEn": "The flight was ten hours late and I hadn't taken my friends' number. I didn't know where to go: nothing could be done before morning. I only managed to reach them two hours later. After that — no more long-distance trips, never again!",
      "questions": [
        {
          "id": "q1",
          "prompt": "Why couldn't Gilles contact his friends at first?",
          "options": [
            {
              "id": "a",
              "text": "He hadn't taken their phone number"
            },
            {
              "id": "b",
              "text": "His phone had been stolen"
            },
            {
              "id": "c",
              "text": "They were on the same flight"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "« Plus aucun voyage lointain, plus jamais ! » — what has Gilles decided?",
          "options": [
            {
              "id": "a",
              "text": "No more long-distance trips, ever"
            },
            {
              "id": "b",
              "text": "To travel more often"
            },
            {
              "id": "c",
              "text": "To take only short flights for a year"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-mc-4",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Compound tense: « Je ___ pris leur numéro de téléphone. »",
      "options": [
        {
          "id": "a",
          "text": "n'avais pas"
        },
        {
          "id": "b",
          "text": "avais ne pas"
        },
        {
          "id": "c",
          "text": "ne pas avais"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "In compound tenses the negation frames the auxiliary: je n'avais pas pris."
    },
