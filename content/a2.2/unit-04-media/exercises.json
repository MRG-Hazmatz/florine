              "id": "b",
              "text": "Deleted their blog"
            },
            {
              "id": "c",
              "text": "Bought a new phone"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "What does the speaker suggest?",
          "options": [
