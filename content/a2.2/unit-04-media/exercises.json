  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Si on allait au cinéma ? » is a way to…",
      "options": [
        {
          "id": "a",
          "text": "make a suggestion"
        },
        {
          "id": "b",
          "text": "talk about the past"
        },
        {
          "id": "c",
          "text": "give an order"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "si + imparfait floats a suggestion: « Si on allait…? » = How about going…?"
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « Je ne vois personne » mean?",
      "options": [
        {
          "id": "a",
          "text": "I don't see anybody"
        },
        {
          "id": "b",
          "text": "I see someone"
        },
        {
          "id": "c",
          "text": "I see something"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "ne… personne = nobody / not anybody."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the negative partner of « quelque chose »?",
      "options": [
        {
          "id": "a",
          "text": "rien"
        },
        {
          "id": "b",
          "text": "personne"
        },
        {
          "id": "c",
          "text": "quelqu'un"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "quelque chose (something) ↔ rien (nothing)."
    },
