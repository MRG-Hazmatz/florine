          "id": "a",
          "text": "most people"
        },
        {
          "id": "b",
          "text": "a few people"
        },
        {
          "id": "c",
          "text": "no one"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "la plupart des + plural = most (of)."
