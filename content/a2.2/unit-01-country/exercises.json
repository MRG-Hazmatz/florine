  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Choose the relative pronoun for a place: « la ville ___ j'habite »",
      "options": [
        {
          "id": "a",
          "text": "où"
        },
        {
          "id": "b",
          "text": "dont"
        },
        {
          "id": "c",
          "text": "que"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "où = where (a place or a time): la ville où j'habite."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "The verb is parler DE. Choose: « le sujet ___ je parle »",
      "options": [
        {
          "id": "a",
          "text": "dont"
        },
        {
          "id": "b",
          "text": "où"
        },
        {
          "id": "c",
          "text": "qui"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "When the phrase uses de (parler de), the relative is dont."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « la plupart des gens » mean?",
      "options": [
