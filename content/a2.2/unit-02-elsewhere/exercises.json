  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Replace a masculine noun: « mon vélo et ___ de Paul »",
      "options": [
        {
          "id": "a",
          "text": "celui"
        },
        {
          "id": "b",
          "text": "celle"
        },
        {
          "id": "c",
          "text": "ceux"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "vélo is masculine singular → celui de Paul (Paul's one)."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Replace a feminine noun: « ma voiture et ___ de Marie »",
