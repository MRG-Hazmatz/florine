    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read and answer both questions.",
      "passageFr": "Lucas habite à Lyon, mais il veut vivre ailleurs. Il a choisi de s'installer au Canada. Le climat est froid, mais la qualité de vie est meilleure que celle de la France, dit-il. Il s'habitue vite à sa nouvelle vie.",
      "passageEn": "Lucas lives in Lyon, but he wants to live elsewhere. He has chosen to settle in Canada. The climate is cold, but the quality of life is better than that of France, he says. He's quickly getting used to his new life.",
      "questions": [
        {
          "id": "q1",
          "prompt": "Where did Lucas choose to move?",
          "options": [
            {
              "id": "a",
              "text": "Canada"
            },
            {
              "id": "b",
              "text": "Lyon"
            },
            {
              "id": "c",
              "text": "Italy"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "How is the quality of life there, according to him?",
          "options": [
            {
              "id": "a",
              "text": "Better than in France"
            },
            {
              "id": "b",
              "text": "Worse than in France"
            },
            {
              "id": "c",
              "text": "Exactly the same"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
