        {
          "id": "a",
          "text": "celle"
        },
        {
          "id": "b",
          "text": "celui"
        },
        {
          "id": "c",
          "text": "celles"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "voiture is feminine singular → celle de Marie."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « celui-ci » mean?",
      "options": [
        {
          "id": "a",
          "text": "this one"
        },
        {
          "id": "b",
          "text": "those ones"
