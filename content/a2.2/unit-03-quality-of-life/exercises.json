  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « la plus grande ville » mean?",
      "options": [
        {
          "id": "a",
          "text": "the biggest city"
        },
        {
          "id": "b",
          "text": "a big city"
        },
        {
          "id": "c",
          "text": "the smallest city"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "le/la plus + adjective = the most… → la plus grande = the biggest."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the superlative of « bon » (good)?",
      "options": [
        {
          "id": "a",
          "text": "le meilleur"
        },
        {
          "id": "b",
          "text": "le plus bon"
        },
        {
          "id": "c",
          "text": "le plus bien"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "bon is irregular: le meilleur (the best), never « le plus bon »."
    },
