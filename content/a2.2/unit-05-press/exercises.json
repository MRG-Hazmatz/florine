  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Emphasise the SUBJECT: « C'est Marie ___ a gagné. »",
      "options": [
        {
          "id": "a",
          "text": "qui"
        },
        {
          "id": "b",
          "text": "que"
        },
        {
          "id": "c",
          "text": "dont"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "c'est … qui highlights the subject (followed by a verb): C'est Marie qui a gagné."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Emphasise the object: « C'est ce film ___ je préfère. »",
      "options": [
        {
          "id": "a",
          "text": "que"
        },
        {
          "id": "b",
          "text": "qui"
        },
        {
          "id": "c",
          "text": "où"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "c'est … que highlights the rest (followed by a subject): C'est ce film que je préfère."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What is the noun (nominalisation) from the verb « augmenter »?",
      "options": [
        {
          "id": "a",
          "text": "une augmentation"
        },
        {
          "id": "b",
          "text": "un augment"
        },
        {
          "id": "c",
          "text": "augmenté"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "augmenter → une augmentation (often used in headlines)."
    },
