{
  "schemaVersion": 1,
  "unitId": "b1.1/unit-02-feelings",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Same subject (you're glad and you're the one coming): « Je suis content ___ . »",
      "options": [
        {
          "id": "a",
          "text": "de venir"
        },
        {
          "id": "b",
          "text": "que je vienne"
        },
        {
          "id": "c",
          "text": "que venir"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Same subject → de + infinitive: je suis content de venir."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Different subjects, subjunctive of être: « Je suis content que tu ___ là. »",
      "options": [
        {
          "id": "a",
          "text": "sois"
        },
        {
          "id": "b",
          "text": "es"
        },
        {
          "id": "c",
          "text": "être"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Different subjects → que + subjonctif: que tu sois."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Subjonctif passé of être (a feeling about something already done).",
      "inputMode": "dropdown",
      "template": "Je suis triste qu'il {{b1}} parti.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "soit"
          ],
          "options": [
            "soit",
            "est"
          ]
        }
      ],
      "explanation": "Subjonctif passé: qu'il soit parti (subjonctif of être + participle)."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Same subject again — link with…?",
      "inputMode": "dropdown",
      "template": "Je suis heureux {{b1}} partir en vacances.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "de"
          ],
          "options": [
            "de",
            "que je"
          ]
        }
      ],
      "explanation": "Same subject → de + infinitive: heureux de partir."
    },
