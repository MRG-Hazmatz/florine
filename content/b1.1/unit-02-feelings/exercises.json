    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: how does the speaker feel?",
      "audio": "audio/b1.1/unit-02-feelings/listen-1.mp3",
      "transcript": "Je suis vraiment heureux que tu sois venu.",
      "options": [
        {
          "id": "a",
          "text": "Happy that you came"
        },
        {
          "id": "b",
          "text": "Angry that you left"
        },
        {
          "id": "c",
          "text": "Afraid of coming"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« heureux que tu sois venu » = happy that you came (subjonctif passé)."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read and answer both questions.",
      "passageFr": "Hier, je me suis disputé avec mon meilleur ami. Je regrette de lui avoir parlé comme ça. J'ai peur qu'il soit encore fâché. J'espère qu'on va se réconcilier vite.",
      "passageEn": "Yesterday, I argued with my best friend. I regret talking to him like that. I'm afraid he's still angry. I hope we'll make up soon.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What happened yesterday?",
          "options": [
            {
              "id": "a",
              "text": "The writer argued with their best friend"
            },
            {
              "id": "b",
              "text": "The writer met a new friend"
            },
            {
              "id": "c",
              "text": "The writer moved house"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "What does the writer hope for?",
          "options": [
            {
              "id": "a",
              "text": "To make up soon"
            },
            {
              "id": "b",
              "text": "To never speak again"
            },
            {
              "id": "c",
              "text": "To move away"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
