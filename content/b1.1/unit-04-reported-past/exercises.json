    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: what did he promise?",
      "audio": "audio/b1.1/unit-04-reported-past/listen-1.mp3",
      "transcript": "Il a promis qu'il rembourserait le client.",
      "options": [
        {
          "id": "a",
          "text": "To refund the customer"
        },
        {
          "id": "b",
          "text": "To close the shop"
        },
        {
          "id": "c",
          "text": "To raise the price"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« il a promis qu'il rembourserait » = he promised he would refund (futur → conditionnel)."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read and answer both questions.",
      "passageFr": "Hier, j'ai appelé le magasin. Le vendeur a dit que mon colis était en retard. Il a affirmé qu'il l'avait envoyé lundi et il a promis qu'il arriverait bientôt.",
      "passageEn": "Yesterday, I called the shop. The salesperson said my parcel was late. He claimed he had sent it on Monday and promised it would arrive soon.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What did the salesperson say about the parcel?",
          "options": [
            {
              "id": "a",
              "text": "It was late"
            },
            {
              "id": "b",
              "text": "It was lost"
            },
            {
              "id": "c",
              "text": "It was delivered"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "What did he promise?",
          "options": [
            {
              "id": "a",
              "text": "That it would arrive soon"
            },
            {
              "id": "b",
              "text": "That he would refund it"
            },
            {
              "id": "c",
              "text": "That he would call back"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-fb-3",
