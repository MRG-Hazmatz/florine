{
  "schemaVersion": 1,
  "unitId": "b1.1/unit-04-reported-past",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Report in the past: « Je viens » → « Il a dit qu'il ___ . »",
      "options": [
        {
          "id": "a",
          "text": "venait"
        },
        {
          "id": "b",
          "text": "vient"
        },
        {
          "id": "c",
          "text": "viendra"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "présent → imparfait: « il venait »."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Report in the past: « J'ai fini » → « Elle a dit qu'elle ___ fini. »",
      "options": [
        {
          "id": "a",
          "text": "avait"
        },
        {
          "id": "b",
          "text": "a"
        },
        {
          "id": "c",
          "text": "aura"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "passé composé → plus-que-parfait: « elle avait fini »."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Report in the past: « Je viendrai » → « Il a promis qu'il ___ . »",
      "options": [
        {
          "id": "a",
          "text": "viendrait"
        },
        {
          "id": "b",
          "text": "viendra"
        },
        {
          "id": "c",
          "text": "venait"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "futur → conditionnel: « il viendrait »."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Report a yes/no question.",
      "inputMode": "dropdown",
      "template": "Elle m'a demandé {{b1}} j'avais le reçu.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "si"
          ],
          "options": [
            "si",
            "que",
            "ce que"
          ]
        }
      ],
      "explanation": "A reported yes/no question uses si: « demander si »."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Report a 'what' question (Qu'est-ce que tu fais ?).",
