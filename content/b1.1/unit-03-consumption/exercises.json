{
  "schemaVersion": 1,
  "unitId": "b1.1/unit-03-consumption",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the comparative of « bon » (good)?",
      "options": [
        {
          "id": "a",
          "text": "meilleur"
        },
        {
          "id": "b",
          "text": "plus bon"
        },
        {
          "id": "c",
          "text": "mieux"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "bon → meilleur (better). mieux is the comparative of the adverb bien."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Compare a quantity: « J'ai ___ temps que toi. » (more time)",
      "options": [
        {
          "id": "a",
          "text": "plus de"
        },
        {
          "id": "b",
          "text": "plus que"
        },
        {
          "id": "c",
          "text": "plus"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "With a noun, use plus de … que: plus de temps que toi."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "After a preposition (masculine thing): « le stylo avec ___ j'écris »",
      "options": [
        {
          "id": "a",
          "text": "lequel"
        },
        {
          "id": "b",
          "text": "laquelle"
        },
        {
          "id": "c",
          "text": "qui"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "stylo is masculine → avec lequel. (qui is only for people.)"
    },
    {
      "id": "ex-mc-4",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "After a preposition (feminine thing): « la raison pour ___ je pars »",
      "options": [
        {
          "id": "a",
          "text": "laquelle"
        },
        {
          "id": "b",
          "text": "lequel"
        },
        {
          "id": "c",
          "text": "dont"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "raison is feminine → pour laquelle (the reason why)."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "The verb is penser À. Contract à + lequel.",
      "inputMode": "dropdown",
      "template": "C'est le problème {{b1}} je pense.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "auquel"
          ],
          "options": [
            "auquel",
            "à lequel",
            "duquel"
          ]
        }
      ],
      "explanation": "à + lequel → auquel: le problème auquel je pense."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Compare adjectives: the train is LESS expensive than the plane.",
