{
  "schemaVersion": 1,
  "unitId": "b1.1/unit-10-purpose-duration",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Different subjects: « Il parle fort ___ tout le monde entende. »",
      "options": [
        {
          "id": "a",
          "text": "pour que"
        },
        {
          "id": "b",
          "text": "pour"
        },
        {
          "id": "c",
          "text": "afin de"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "He speaks, everyone hears — different subjects → pour que + subjonctif."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Same subject: « Je fais du sport ___ rester en forme. »",
      "options": [
        {
          "id": "a",
          "text": "pour"
        },
        {
          "id": "b",
          "text": "pour que"
        },
        {
          "id": "c",
          "text": "afin que"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "I exercise, I stay fit — same subject → pour + infinitif."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Still true today — choose the time word.",
      "inputMode": "dropdown",
      "template": "J'habite ici {{b1}} 2019.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "depuis"
          ],
          "options": [
            "depuis",
            "pendant",
            "il y a"
          ]
        }
      ],
      "explanation": "Started in 2019 and still true → depuis."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "A finished period — choose the time word.",
      "inputMode": "dropdown",
      "template": "J'ai vécu à Lyon {{b1}} deux ans.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "pendant"
          ],
          "options": [
            "pendant",
            "depuis",
            "dans"
          ]
        }
      ],
      "explanation": "A closed, finished period (passé composé, it's over) → pendant."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Time it took: « J'ai fini l'exercice ___ dix minutes. »",
      "options": [
        {
          "id": "a",
          "text": "en"
        },
        {
          "id": "b",
          "text": "dans"
        },
        {
          "id": "c",
          "text": "depuis"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "The time needed to complete something → en dix minutes."
    },
    {
      "id": "ex-fb-3",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Complete « ago » in French (one word).",
      "inputMode": "typed",
      "template": "Nous sommes arrivés il y {{b1}} trois jours.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "a"
          ]
        }
      ],
      "explanation": "Il y a + duration = ago: il y a trois jours."
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each time word to its job.",
      "pairs": [
        {
          "id": "p1",
          "left": "depuis",
          "right": "since / for (still ongoing)"
        },
        {
          "id": "p2",
          "left": "pendant",
          "right": "for (a closed period)"
        },
        {
          "id": "p3",
          "left": "dans",
          "right": "in (from now, future)"
        },
        {
          "id": "p4",
          "left": "il y a",
          "right": "ago"
        }
      ]
    },
