    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen to the volunteer. How long has she volunteered, and when does she leave?",
      "audio": "audio/b1.1/unit-10-purpose-duration/listen-1.mp3",
      "transcript": "Je suis bénévole depuis trois ans ; je pars au Sénégal dans deux semaines pour une mission de six mois.",
      "options": [
        {
          "id": "a",
          "text": "Volunteer for three years — leaving in two weeks for a six-month mission"
        },
        {
          "id": "b",
          "text": "Volunteer for two weeks — leaving in three years"
        },
        {
          "id": "c",
          "text": "Volunteer for six months — leaving in three days"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "depuis trois ans (ongoing) · dans deux semaines (future) · pour une mission de six mois (planned duration)."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read the association's page and answer both questions.",
      "passageFr": "L'association Mains Ouvertes existe depuis 1995. Pendant ses dix premières années, elle aidait seulement les familles du quartier. Aujourd'hui, elle récolte des fonds dans toute la France afin que chaque enfant puisse manger à l'école. Sa prochaine campagne commence dans un mois.",
      "passageEn": "The charity Mains Ouvertes has existed since 1995. During its first ten years, it only helped families in the neighbourhood. Today it raises funds across France so that every child can eat at school. Its next campaign starts in a month.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What is the charity's GOAL today (« afin que… ») ?",
          "options": [
            {
              "id": "a",
              "text": "That every child can eat at school"
            },
            {
              "id": "b",
              "text": "To help only neighbourhood families"
            },
            {
              "id": "c",
              "text": "To open a new school in a month"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "When does the next campaign start?",
          "options": [
            {
              "id": "a",
              "text": "In a month"
            },
            {
              "id": "b",
              "text": "It started a month ago"
            },
            {
              "id": "c",
              "text": "In 1995"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-mc-4",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "After « pour que », the verb is in the…",
      "options": [
        {
          "id": "a",
          "text": "subjonctif — pour que tout le monde comprenne"
        },
        {
          "id": "b",
          "text": "indicatif — pour que tout le monde comprend"
        },
        {
          "id": "c",
          "text": "infinitif — pour que comprendre"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Pour que / afin que always take the subjunctive: …pour que tout le monde comprenne."
    },
