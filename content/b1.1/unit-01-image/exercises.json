    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "The verb is parler DE. Choose: « la personne ___ je parle »",
      "options": [
        {
          "id": "a",
          "text": "dont"
        },
        {
          "id": "b",
          "text": "qui"
        },
        {
          "id": "c",
          "text": "que"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "A de-verb (parler de) → dont: la personne dont je parle."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Complete with 'the one who': « ___ qui se présente bien séduit. »",
