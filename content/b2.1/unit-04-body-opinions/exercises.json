      ],
      "explanation": "Être reconnaissant que (feeling) → subjonctif: que tu sois là."
    },
    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Which reply REFUSES the request?",
      "options": [
        {
          "id": "a",
          "text": "Tu peux toujours courir !"
        },
        {
          "id": "b",
          "text": "À ta guise."
        },
        {
          "id": "c",
          "text": "Je te donne carte blanche."
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Tu peux toujours courir ! = spoken, ironic refusal. The other two grant permission."
    },
