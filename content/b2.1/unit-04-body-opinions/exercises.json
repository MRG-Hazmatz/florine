  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Certainty verb — pick the mood: « Vous êtes certains qu'il ___ . »",
      "options": [
        {
          "id": "a",
          "text": "viendra"
        },
        {
          "id": "b",
          "text": "vienne"
        },
        {
          "id": "c",
          "text": "soit venu"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Être certain que = certainty → INDICATIF: qu'il viendra."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Judgment expression — pick the mood: « Je ne comprends pas qu'on ___ mentir. »",
      "options": [
        {
          "id": "a",
          "text": "puisse"
        },
        {
          "id": "b",
          "text": "peut"
        },
        {
          "id": "c",
          "text": "pourra"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Ne pas comprendre que = judgment/incomprehension → SUBJONCTIF: qu'on puisse."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Gratitude takes a mood too.",
      "inputMode": "dropdown",
      "template": "Je suis reconnaissante que tu {{b1}} là.",
      "blanks": [
