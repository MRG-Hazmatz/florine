    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen to the consultation. What does the doctor say?",
      "audio": "audio/b2.1/unit-04-body-opinions/listen-1.mp3",
      "transcript": "Je vous prescris un traitement ; je suis certain que ça vous soulagera, mais c'est hors de question de reprendre le sport avant un mois.",
      "options": [
        {
          "id": "a",
          "text": "The treatment will bring relief, but sport is off-limits for a month"
        },
        {
          "id": "b",
          "text": "Sport will relieve the pain, starting this week"
        },
        {
          "id": "c",
          "text": "There is no treatment for this pain"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« ça vous soulagera » + « hors de question de reprendre le sport avant un mois »."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read the exchange between flatmates and answer both questions.",
      "passageFr": "LÉA : Je voudrais repeindre le salon en violet. Tu me laisses faire ?\nSAM : Pour les couleurs, je te fais entièrement confiance — carte blanche ! Mais toucher à ma bibliothèque, c'est hors de question.\nLÉA : Et si on déplaçait juste le canapé ?\nSAM : À ta guise. Je n'y tiens pas particulièrement, mais fais comme tu veux.",
      "passageEn": "LÉA: I'd like to repaint the living room purple. Will you let me?\nSAM: For colours, I trust you completely — free rein! But touching my bookshelf is out of the question.\nLÉA: What if we just moved the sofa?\nSAM: As you wish. I'm not particularly keen, but do as you like.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What does Sam refuse outright?",
          "options": [
            {
              "id": "a",
              "text": "Touching his bookshelf"
            },
            {
              "id": "b",
              "text": "Repainting the living room"
            },
            {
              "id": "c",
              "text": "Moving the sofa"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "« À ta guise » means…",
          "options": [
            {
              "id": "a",
              "text": "As you wish"
            },
            {
              "id": "b",
              "text": "Absolutely not"
            },
            {
              "id": "c",
              "text": "I insist on it"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-mc-4",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "The false-friend pair — which sentence is correct?",
      "options": [
        {
          "id": "a",
          "text": "Je suis sûr que c'est vrai. / C'est dommage que ce soit vrai."
        },
        {
          "id": "b",
          "text": "Je suis sûr que ce soit vrai. / C'est dommage que c'est vrai."
        },
        {
          "id": "c",
          "text": "Both take the subjunctive."
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Être sûr que → indicatif (certainty); c'est dommage que → subjonctif (judgment)."
    },
