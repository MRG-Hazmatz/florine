      "skill": "writing",
      "prompt": "Which compound is built correctly?",
      "options": [
        {
          "id": "a",
          "text": "une machine à laver"
        },
        {
          "id": "b",
          "text": "une machine de laver"
        },
        {
          "id": "c",
          "text": "une machine en laver"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Purpose + verb → à + infinitive: une machine à laver, une salle à manger."
    },
