  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Purpose or content? \"An (empty) coffee cup\" is…",
      "options": [
        {
          "id": "a",
          "text": "une tasse à café"
        },
        {
          "id": "b",
          "text": "une tasse de café"
        },
        {
          "id": "c",
          "text": "une tasse en café"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "à = purpose (designed for coffee). Une tasse de café = a cup full of coffee."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Material: « un sac ___ cuir »",
      "options": [
        {
          "id": "a",
          "text": "en"
        },
        {
          "id": "b",
          "text": "à"
        },
        {
          "id": "c",
          "text": "pour"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Material → en: un sac en cuir, une table en bois."
    },
    {
