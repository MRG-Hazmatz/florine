    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen to the office chat. What's the rumour?",
      "audio": "audio/b2.1/unit-09-work-conditional/listen-1.mp3",
      "transcript": "D'après Sophie, une augmentation serait prévue pour mars — tu aurais dû la demander plus tôt !",
      "options": [
        {
          "id": "a",
          "text": "A pay rise is reportedly planned for March"
        },
        {
          "id": "b",
          "text": "Sophie was fired in March"
        },
        {
          "id": "c",
          "text": "Salaries will definitely be cut in March"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« serait prévue » — the conditional flags it as a rumour, not a confirmed fact."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read the internal memo and answer both questions.",
      "passageFr": "NOTE DE SERVICE — Selon la presse, notre concurrent verserait des primes deux fois par an. La direction tient à rassurer les équipes : une prime exceptionnelle sera versée en juin, et il vaudrait mieux ignorer les rumeurs. Les salariés qui auraient des questions sur leur salaire peuvent contacter les ressources humaines.",
      "passageEn": "MEMO — According to the press, our competitor reportedly pays bonuses twice a year. Management wishes to reassure the teams: an exceptional bonus WILL be paid in June, and it would be better to ignore the rumours. Employees who may have questions about their salary can contact human resources.",
      "questions": [
        {
          "id": "q1",
          "prompt": "« Le concurrent verserait des primes » — why the conditional?",
          "options": [
            {
              "id": "a",
              "text": "It's unconfirmed press information"
            },
            {
              "id": "b",
              "text": "It's a reproach to the competitor"
            },
            {
              "id": "c",
              "text": "It's a polite request"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "What is CONFIRMED in the memo?",
          "options": [
            {
              "id": "a",
              "text": "An exceptional bonus will be paid in June"
            },
            {
              "id": "b",
              "text": "Salaries will double"
            },
            {
              "id": "c",
              "text": "The competitor pays better"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
