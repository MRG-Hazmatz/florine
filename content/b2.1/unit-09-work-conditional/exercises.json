  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Vous auriez dû rappeler le client ! » — what does the conditional express?",
      "options": [
        {
          "id": "a",
          "text": "A reproach"
        },
        {
          "id": "b",
          "text": "A polite demand"
        },
        {
          "id": "c",
          "text": "Unconfirmed news"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Conditionnel passé + devoir = reproach: you should have…"
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Une grève serait prévue lundi. » — what does the conditional express?",
      "options": [
        {
          "id": "a",
          "text": "Unconfirmed information (a rumour)"
        },
        {
          "id": "b",
          "text": "A regret"
        },
        {
          "id": "c",
          "text": "A piece of advice"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Serait + reported fact = the journalistic conditional: reportedly planned."
    },
