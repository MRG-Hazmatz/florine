    {
      "id": "ex-mc-3",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Which contract is PERMANENT?",
      "options": [
        {
          "id": "a",
          "text": "un CDI"
        },
        {
          "id": "b",
          "text": "un CDD"
        },
        {
          "id": "c",
          "text": "un stage"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "CDI = contrat à durée indéterminée (permanent); CDD = fixed-term."
    },
    {
      "id": "ex-fb-3",
