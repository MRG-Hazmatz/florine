{
  "schemaVersion": 1,
  "unitId": "b2.1/unit-10-contract-claims",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Imperative + two pronouns: \"Give it back to me\" =",
      "options": [
        {
          "id": "a",
          "text": "Rends-le-moi."
        },
        {
          "id": "b",
          "text": "Rends-moi-le."
        },
        {
          "id": "c",
          "text": "Me le rends."
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Affirmative imperative: verb + direct + indirect, hyphenated: rends-le-moi."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Negative imperative: \"Don't talk to him about it\" =",
      "options": [
        {
          "id": "a",
          "text": "Ne lui en parlez pas."
        },
        {
          "id": "b",
          "text": "Ne parlez-lui-en pas."
        },
        {
          "id": "c",
          "text": "Parlez-ne-lui-en pas."
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Negative imperative goes back to normal order: ne lui en parlez pas."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Give me some!",
      "inputMode": "dropdown",
      "template": "Des congés ? Donnez-{{b1}} deux semaines !",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "m'en"
          ],
          "options": [
            "m'en",
            "moi-en",
            "moi en"
          ]
        }
      ],
      "explanation": "Moi becomes m' before en: donnez-m'en."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Union demand — watch the mood.",
      "inputMode": "dropdown",
      "template": "Nous exigeons que le contrat {{b1}} respecté.",
      "blanks": [
