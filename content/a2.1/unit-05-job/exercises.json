{
  "schemaVersion": 1,
  "unitId": "a2.1/unit-05-job",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "« Je travaille ici depuis 2020 » means I've worked here…",
      "options": [
        {
          "id": "a",
          "text": "since 2020 (and still do)"
        },
        {
          "id": "b",
          "text": "back in 2020 only"
        },
        {
          "id": "c",
          "text": "until 2020"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "depuis = since / for, for something still going on now."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "For an action that is STILL going on, which word do you use?",
      "options": [
        {
          "id": "a",
          "text": "depuis"
        },
        {
          "id": "b",
          "text": "pendant"
        },
        {
          "id": "c",
          "text": "il y a"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "depuis = ongoing; pendant = a finished span; il y a = ago."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "A finished period of two years → which word?",
      "inputMode": "dropdown",
      "template": "J'ai habité à Paris {{b1}} deux ans.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "pendant"
          ],
          "options": [
            "pendant",
            "depuis"
          ]
        }
      ],
      "explanation": "It's over → pendant deux ans. (depuis would mean you still live there.)"
    },
