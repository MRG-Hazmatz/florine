    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: what did the speaker do?",
      "audio": "audio/a2.1/unit-05-job/listen-1.mp3",
      "transcript": "J'ai envoyé mon CV pour ce poste.",
      "options": [
        {
          "id": "a",
          "text": "Sent their CV for the position"
        },
        {
          "id": "b",
          "text": "Quit their job"
        },
        {
          "id": "c",
          "text": "Asked for a raise"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« j'ai envoyé mon CV pour ce poste » = I sent my CV for this position."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read and answer both questions.",
      "passageFr": "Bonjour, je m'appelle Lucie. Je cherche un emploi dans le marketing. J'ai un diplôme et trois ans d'expérience. Je travaille dans une entreprise depuis 2021, mais je voudrais changer.",
      "passageEn": "Hello, my name is Lucie. I'm looking for a job in marketing. I have a degree and three years of experience. I've worked at a company since 2021, but I'd like a change.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What field does Lucie want to work in?",
          "options": [
            {
              "id": "a",
              "text": "Marketing"
            },
            {
              "id": "b",
              "text": "Medicine"
            },
            {
              "id": "c",
              "text": "Teaching"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "Since when has Lucie worked at her company?",
          "options": [
            {
              "id": "a",
              "text": "Since 2021"
            },
            {
              "id": "b",
              "text": "For two months"
            },
            {
              "id": "c",
              "text": "She doesn't have a job"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "A point in the past (a month ago) → which word?",
      "inputMode": "dropdown",
      "template": "J'ai trouvé ce travail {{b1}} un mois.",
      "blanks": [
