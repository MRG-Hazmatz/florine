      "transcript": "Il faut que tu sois à l'heure pour l'entretien.",
      "options": [
        {
          "id": "a",
          "text": "Be on time for the interview"
        },
        {
          "id": "b",
          "text": "Bring your CV"
        },
        {
          "id": "c",
          "text": "Call the boss"
        }
