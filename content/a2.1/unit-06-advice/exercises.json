{
  "schemaVersion": 1,
  "unitId": "a2.1/unit-06-advice",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "After « il faut que », which verb form do you use?",
      "options": [
        {
          "id": "a",
          "text": "the subjunctive (subjonctif)"
        },
        {
          "id": "b",
          "text": "the future"
        },
        {
          "id": "c",
          "text": "the infinitive"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "il faut que triggers the subjunctive: il faut que tu sois, que tu aies…"
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Subjunctive of être: « Il faut que tu ___ à l'heure. »",
      "options": [
        {
          "id": "a",
          "text": "sois"
        },
        {
          "id": "b",
          "text": "es"
        },
        {
          "id": "c",
          "text": "être"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "être in the subjunctive: que tu sois."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Give advice with devoir (you must prepare).",
      "inputMode": "dropdown",
      "template": "Tu {{b1}} préparer l'entretien.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "dois"
          ],
          "options": [
            "dois",
            "faut"
          ]
        }
      ],
      "explanation": "devoir: tu dois + infinitive. ('il faut' is impersonal — il faut préparer.)"
    },
