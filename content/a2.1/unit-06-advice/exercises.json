      "explanation": "« il faut que tu sois à l'heure » = you must be on time."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read the advice and answer both questions.",
      "passageFr": "Voici mes conseils pour un entretien : il faut que tu sois à l'heure. Tu dois être poli et motivé. Il est important de bien te préparer. Bonne chance !",
      "passageEn": "Here's my advice for an interview: you must be on time. You must be polite and motivated. It's important to prepare well. Good luck!",
      "questions": [
        {
          "id": "q1",
          "prompt": "What should you be at the interview?",
          "options": [
            {
              "id": "a",
              "text": "Polite and motivated"
            },
            {
              "id": "b",
              "text": "Late and quiet"
            },
            {
              "id": "c",
              "text": "Funny and loud"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "What is important?",
          "options": [
            {
              "id": "a",
              "text": "To prepare well"
            },
            {
              "id": "b",
              "text": "To bring food"
            },
            {
              "id": "c",
              "text": "To arrive late"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
