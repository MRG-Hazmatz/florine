{
  "schemaVersion": 1,
  "unitId": "a2.1/unit-04-studies",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "The plus-que-parfait describes an action that happened…",
      "options": [
        {
          "id": "a",
          "text": "before another past action"
        },
        {
          "id": "b",
          "text": "in the near future"
        },
        {
          "id": "c",
          "text": "right now"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "It's the 'past of the past': J'avais fini quand il est arrivé."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the adverb from « heureux » (feminine: heureuse)?",
      "options": [
        {
          "id": "a",
          "text": "heureusement"
        },
        {
          "id": "b",
          "text": "heureuxment"
        },
        {
          "id": "c",
          "text": "heureuse"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Feminine adjective + -ment: heureuse → heureusement."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Form the plus-que-parfait (I had already eaten).",
      "inputMode": "dropdown",
      "template": "Quand il est arrivé, j'{{b1}} déjà mangé.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "avais"
          ],
          "options": [
            "avais",
            "ai"
          ]
        }
      ],
      "explanation": "Plus-que-parfait = avoir in the imparfait + participle: j'avais mangé."
    },
