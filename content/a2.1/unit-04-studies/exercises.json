    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: what did the speaker do last year?",
      "audio": "audio/a2.1/unit-04-studies/listen-1.mp3",
      "transcript": "L'année dernière, j'ai fait un échange en Espagne.",
      "options": [
        {
          "id": "a",
          "text": "An exchange in Spain"
        },
        {
          "id": "b",
          "text": "An exam in France"
        },
        {
          "id": "c",
          "text": "A job in Italy"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« j'ai fait un échange en Espagne » = I did an exchange in Spain."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read and answer both questions.",
      "passageFr": "Marie a toujours aimé les langues. À l'université, elle a obtenu une bourse et elle a fait un échange en Italie. Avant, elle n'avait jamais voyagé à l'étranger.",
      "passageEn": "Marie has always loved languages. At university, she got a scholarship and did an exchange in Italy. Before, she had never travelled abroad.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What did Marie get at university?",
          "options": [
            {
              "id": "a",
              "text": "A scholarship"
            },
            {
              "id": "b",
              "text": "A job"
            },
            {
              "id": "c",
              "text": "A car"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "Had Marie travelled abroad before?",
          "options": [
            {
              "id": "a",
              "text": "No, never"
            },
            {
              "id": "b",
              "text": "Yes, many times"
            },
            {
              "id": "c",
              "text": "Yes, once"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Complete with the adverb for 'slowly'.",
