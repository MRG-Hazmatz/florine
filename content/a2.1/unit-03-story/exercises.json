      "correct": [
        "a"
      ],
      "explanation": "« il y a cinq ans » = five years ago."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read the story and answer both questions.",
      "passageFr": "C'était un dimanche. Il faisait beau et j'étais au parc. Tout à coup, j'ai vu une fille qui souriait. On a parlé pendant une heure. C'était le coup de foudre !",
      "passageEn": "It was a Sunday. The weather was nice and I was at the park. Suddenly, I saw a girl who was smiling. We talked for an hour. It was love at first sight!",
      "questions": [
        {
          "id": "q1",
          "prompt": "What was the weather like?",
          "options": [
            {
              "id": "a",
              "text": "It was nice"
            },
            {
              "id": "b",
              "text": "It was raining"
            },
            {
              "id": "c",
              "text": "It was cold"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "How long did they talk?",
          "options": [
            {
              "id": "a",
              "text": "An hour"
            },
            {
              "id": "b",
              "text": "Five minutes"
            },
            {
              "id": "c",
              "text": "All day"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
