{
  "schemaVersion": 1,
  "unitId": "a2.1/unit-03-story",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "In a story, which tense sets the SCENE and background?",
      "options": [
        {
          "id": "a",
          "text": "the imparfait"
        },
        {
          "id": "b",
          "text": "the passé composé"
        },
        {
          "id": "c",
          "text": "the futur proche"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Imparfait = background/description; passé composé = the events that happen."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « il y a deux ans » mean?",
      "options": [
        {
          "id": "a",
          "text": "two years ago"
        },
        {
          "id": "b",
          "text": "in two years"
        },
        {
          "id": "c",
          "text": "for two years"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "il y a + a duration = ago. (dans = in/within; pendant = for/during.)"
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Background description → which tense? « Hier, il ___ beau. »",
      "inputMode": "dropdown",
      "template": "Hier, il {{b1}} beau, alors je suis sorti.",
      "blanks": [
