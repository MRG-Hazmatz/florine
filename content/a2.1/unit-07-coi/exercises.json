      "transcript": "Je vais leur téléphoner ce soir.",
      "options": [
        {
          "id": "a",
          "text": "Them"
        },
        {
          "id": "b",
          "text": "Him only"
        },
        {
          "id": "c",
          "text": "No one"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« leur » = to them: I'm going to phone them tonight."
