        {
          "id": "q1",
          "prompt": "How often does the writer talk to Marie?",
          "options": [
            {
              "id": "a",
              "text": "Every day"
            },
            {
              "id": "b",
              "text": "Once a year"
            },
            {
              "id": "c",
              "text": "Never"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "What will the writer give Marie?",
          "options": [
            {
              "id": "a",
              "text": "A book"
            },
            {
              "id": "b",
              "text": "Flowers"
            },
            {
              "id": "c",
              "text": "Nothing"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
