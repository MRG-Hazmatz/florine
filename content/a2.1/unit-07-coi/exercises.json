  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Replace 'à Marie': « Je téléphone à Marie » → « Je ___ téléphone. »",
      "options": [
        {
          "id": "a",
          "text": "lui"
        },
        {
          "id": "b",
          "text": "le"
        },
        {
          "id": "c",
          "text": "la"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "téléphoner À quelqu'un → indirect → lui (to him/her)."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Replace 'à mes amis': « J'écris à mes amis » → « Je ___ écris. »",
      "options": [
        {
          "id": "a",
          "text": "leur"
        },
        {
          "id": "b",
          "text": "les"
        },
        {
          "id": "c",
          "text": "lui"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "écrire À plusieurs personnes → leur (to them)."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Replace 'à Paul' (donner À quelqu'un).",
      "inputMode": "dropdown",
      "template": "Tu donnes le livre à Paul ? Oui, je {{b1}} donne le livre.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "lui"
          ],
          "options": [
            "lui",
            "le"
          ]
        }
      ],
      "explanation": "donner À Paul → lui (indirect). 'le' would replace the book, not Paul."
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Direct object this time (voir + no preposition).",
      "inputMode": "dropdown",
      "template": "Tu vois Marie ? Oui, je {{b1}} vois.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "la"
          ],
          "options": [
            "la",
            "lui"
          ]
        }
      ],
      "explanation": "voir quelqu'un (no à) → direct → la (her). lui is only for à-verbs."
    },
