    { "id": "chemise", "fr": "la chemise", "en": "shirt", "pos": "noun", "exampleFr": "Tu aimes la chemise ?", "exampleEn": "Do you like the shirt?", "audio": "audio/a1.2/unit-06-shopping/vocab-chemise.mp3", "voice": "henri" },
