    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Paris is BIGGER than Lyon. Complete: « Paris est ___ Lyon. »",
      "options": [
        {
          "id": "a",
          "text": "plus grand que"
        },
        {
          "id": "b",
          "text": "moins grand que"
        },
        {
          "id": "c",
          "text": "aussi grand que"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "plus … que = more … than → plus grand que (bigger than)."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « moins cher que » mean?",
