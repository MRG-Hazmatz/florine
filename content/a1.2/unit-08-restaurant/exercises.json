          "prompt": "How is the dish of the day?",
          "options": [
            {
              "id": "a",
              "text": "Delicious"
            },
            {
              "id": "b",
              "text": "Too cold"
            },
            {
              "id": "c",
              "text": "Not ready"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "Is the restaurant expensive?",
          "options": [
            {
              "id": "a",
              "text": "No, it's not expensive"
            },
            {
              "id": "b",
              "text": "Yes, very expensive"
            },
            {
              "id": "c",
              "text": "It doesn't say"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
