{
  "schemaVersion": 1,
  "unitId": "a1.2/unit-08-restaurant",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "In French, where do MOST descriptive adjectives go?",
      "options": [
        {
          "id": "a",
          "text": "After the noun"
        },
        {
          "id": "b",
          "text": "Before the noun"
        },
        {
          "id": "c",
          "text": "It never matters"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Most adjectives follow the noun: un plat délicieux, une ville moderne."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Which adjective comes BEFORE the noun?",
      "options": [
        {
          "id": "a",
          "text": "bon"
        },
        {
          "id": "b",
          "text": "délicieux"
        },
        {
          "id": "c",
          "text": "moderne"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "bon is in the small 'before' group (size/age/beauty/goodness): un bon plat."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Ask for the bill at the end of the meal.",
