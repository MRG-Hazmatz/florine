{
  "schemaVersion": 1,
  "unitId": "a1.2/unit-08-restaurant",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "In French, where do MOST descriptive adjectives go?",
      "options": [
        { "id": "a", "text": "After the noun" },
        { "id": "b", "text": "Before the noun" },
        { "id": "c", "text": "It never matters" }
      ],
      "correct": ["a"],
      "explanation": "Most adjectives follow the noun: un plat délicieux, une ville moderne."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "Which adjective comes BEFORE the noun?",
      "options": [
        { "id": "a", "text": "bon" },
        { "id": "b", "text": "délicieux" },
        { "id": "c", "text": "moderne" }
      ],
      "correct": ["a"],
      "explanation": "bon is in the small 'before' group (size/age/beauty/goodness): un bon plat."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Ask for the bill at the end of the meal.",
      "inputMode": "typed",
      "template": "L'{{b1}}, s'il vous plaît !",
      "blanks": [{ "id": "b1", "accept": ["addition"] }],
      "explanation": "l'addition = the bill / check."
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each restaurant word to its English meaning.",
      "pairs": [
        { "id": "p1", "left": "le menu", "right": "menu" },
        { "id": "p2", "left": "le plat", "right": "dish" },
        { "id": "p3", "left": "l'addition", "right": "the bill" },
        { "id": "p4", "left": "le serveur", "right": "waiter" }
      ]
    },
    {
      "id": "ex-ro-1",
      "type": "reorder",
      "skill": "writing",
      "prompt": "Put the words in order to say \"This dish is delicious.\"",
      "tokens": [
        { "id": "t1", "text": "Ce" },
        { "id": "t2", "text": "plat" },
        { "id": "t3", "text": "est" },
        { "id": "t4", "text": "délicieux" }
      ],
      "correctOrder": ["t1", "t2", "t3", "t4"]
    },
    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: what does the customer want to do?",
      "audio": "audio/a1.2/unit-08-restaurant/listen-1.mp3",
      "transcript": "Bonjour, je voudrais commander le plat du jour.",
      "options": [
        { "id": "a", "text": "Order the dish of the day" },
        { "id": "b", "text": "Book a table for four" },
        { "id": "c", "text": "Pay the bill" }
      ],
      "correct": ["a"],
      "explanation": "« je voudrais commander le plat du jour » = I'd like to order the dish of the day."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read and answer both questions.",
      "passageFr": "J'aime ce petit restaurant. Le plat du jour est délicieux et le serveur est très gentil. L'addition n'est pas chère.",
      "passageEn": "I like this little restaurant. The dish of the day is delicious and the waiter is very nice. The bill isn't expensive.",
      "questions": [
        {
          "id": "q1",
          "prompt": "How is the dish of the day?",
          "options": [
            { "id": "a", "text": "Delicious" },
            { "id": "b", "text": "Too cold" },
            { "id": "c", "text": "Not ready" }
          ],
          "correct": ["a"]
        },
        {
          "id": "q2",
          "prompt": "Is the restaurant expensive?",
          "options": [
            { "id": "a", "text": "No, it's not expensive" },
            { "id": "b", "text": "Yes, very expensive" },
            { "id": "c", "text": "It doesn't say" }
          ],
          "correct": ["a"]
        }
      ]
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Choose the adjective that fits BEFORE the noun (a good restaurant).",
      "inputMode": "dropdown",
      "template": "C'est un {{b1}} restaurant.",
      "blanks": [{ "id": "b1", "accept": ["bon"], "options": ["bon", "délicieux"] }],
      "explanation": "bon goes before the noun: un bon restaurant."
    }
  ]
}
