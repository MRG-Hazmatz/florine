      "prompt": "Listen, then: what does the customer want to do?",
      "audio": "audio/a1.2/unit-08-restaurant/listen-1.mp3",
      "transcript": "Bonjour, je voudrais commander le plat du jour.",
      "options": [
        {
          "id": "a",
          "text": "Order the dish of the day"
        },
        {
          "id": "b",
          "text": "Book a table for four"
        },
        {
          "id": "c",
          "text": "Pay the bill"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« je voudrais commander le plat du jour » = I'd like to order the dish of the day."
