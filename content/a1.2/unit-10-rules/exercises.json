{
  "schemaVersion": 1,
  "unitId": "a1.2/unit-10-rules",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « il faut » + infinitive mean?",
      "options": [
        {
          "id": "a",
          "text": "You have to / it's necessary to"
        },
        {
          "id": "b",
          "text": "You are"
        },
        {
          "id": "c",
          "text": "There was"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "il faut + infinitive expresses obligation: Il faut payer = you have to pay."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "Which sentence says something is FORBIDDEN?",
      "options": [
        {
          "id": "a",
          "text": "Il est interdit de fumer."
        },
        {
          "id": "b",
          "text": "Il faut fumer."
        },
        {
          "id": "c",
          "text": "Je fume une cigarette."
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Il est interdit de + infinitive = it is forbidden to…"
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Complete the prohibition (you must NOT make noise).",
      "inputMode": "typed",
      "template": "Il ne {{b1}} pas faire de bruit.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "faut"
          ]
        }
      ],
      "explanation": "il ne faut pas + infinitive = you must not…"
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each word to its English meaning.",
