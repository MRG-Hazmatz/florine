          "left": "le loyer",
          "right": "rent"
        },
        {
          "id": "p2",
          "left": "le voisin",
          "right": "neighbour"
        },
        {
          "id": "p3",
          "left": "le bruit",
          "right": "noise"
        },
        {
          "id": "p4",
          "left": "la poubelle",
          "right": "the bin"
        }
      ]
    },
    {
      "id": "ex-ro-1",
      "type": "reorder",
      "skill": "writing",
      "prompt": "Put the words in order to say \"You have to pay the rent.\"",
      "tokens": [
        {
          "id": "t1",
          "text": "Il"
        },
        {
          "id": "t2",
          "text": "faut"
        },
        {
          "id": "t3",
          "text": "payer"
        },
        {
          "id": "t4",
          "text": "le"
        },
        {
          "id": "t5",
          "text": "loyer"
        }
      ],
      "correctOrder": [
        "t1",
        "t2",
        "t3",
        "t4",
        "t5"
      ]
    },
    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: what must you do?",
      "audio": "audio/a1.2/unit-10-rules/listen-1.mp3",
      "transcript": "Dans la colocation, il faut respecter les voisins.",
      "options": [
        {
          "id": "a",
          "text": "Respect the neighbours"
        },
        {
          "id": "b",
          "text": "Pay double rent"
        },
        {
          "id": "c",
          "text": "Leave the flat"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "« il faut respecter les voisins » = you must respect the neighbours."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read the house rules and answer both questions.",
      "passageFr": "Règles de la maison : il faut ranger la cuisine après le dîner. Il ne faut pas faire de bruit après 22 heures. Il est interdit de fumer dans l'appartement.",
      "passageEn": "House rules: you must tidy the kitchen after dinner. You mustn't make noise after 10 pm. Smoking is forbidden in the apartment.",
      "questions": [
        {
          "id": "q1",
          "prompt": "What must you do after dinner?",
          "options": [
            {
              "id": "a",
              "text": "Tidy the kitchen"
            },
            {
              "id": "b",
              "text": "Pay the rent"
            },
            {
              "id": "c",
              "text": "Call the neighbours"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "What is forbidden?",
          "options": [
            {
              "id": "a",
              "text": "Smoking in the apartment"
            },
            {
              "id": "b",
              "text": "Cooking after 10 pm"
            },
            {
              "id": "c",
              "text": "Having guests"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Express obligation (you must do the housework every week).",
      "inputMode": "dropdown",
      "template": "{{b1}} faire le ménage chaque semaine.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "Il faut"
          ],
          "options": [
            "Il faut",
            "Il est"
          ]
        }
      ],
      "explanation": "Il faut + infinitive = you must. 'Il est faire' is not grammatical."
    },
