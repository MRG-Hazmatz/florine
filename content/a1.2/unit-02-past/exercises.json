{
  "schemaVersion": 1,
  "unitId": "a1.2/unit-02-past",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What is « je mange » in the passé composé (past)?",
      "options": [
        {
          "id": "a",
          "text": "j'ai mangé"
        },
        {
          "id": "b",
          "text": "je mangé"
        },
        {
          "id": "c",
          "text": "j'ai manger"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "avoir (j'ai) + past participle (mangé). Not the infinitive 'manger'."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the past participle of « regarder »?",
      "options": [
        {
          "id": "a",
          "text": "regardé"
        },
        {
          "id": "b",
          "text": "regarder"
        },
        {
          "id": "c",
          "text": "regardez"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "-er verbs → -é: regarder → regardé."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Add the correct form of avoir (the auxiliary).",
      "inputMode": "typed",
      "template": "Hier, nous {{b1}} regardé un film.",
      "blanks": [
        {
          "id": "b1",
          "accept": [
            "avons"
          ]
