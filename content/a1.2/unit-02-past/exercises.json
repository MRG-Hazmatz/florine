{
  "schemaVersion": 1,
  "unitId": "a1.2/unit-02-past",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What is « je mange » in the passé composé (past)?",
      "options": [
        { "id": "a", "text": "j'ai mangé" },
        { "id": "b", "text": "je mangé" },
        { "id": "c", "text": "j'ai manger" }
      ],
      "correct": ["a"],
      "explanation": "avoir (j'ai) + past participle (mangé). Not the infinitive 'manger'."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "What is the past participle of « regarder »?",
      "options": [
        { "id": "a", "text": "regardé" },
        { "id": "b", "text": "regarder" },
        { "id": "c", "text": "regardez" }
      ],
      "correct": ["a"],
      "explanation": "-er verbs → -é: regarder → regardé."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Add the correct form of avoir (the auxiliary).",
      "inputMode": "typed",
      "template": "Hier, nous {{b1}} regardé un film.",
      "blanks": [{ "id": "b1", "accept": ["avons"] }],
      "explanation": "nous avons + regardé."
    },
    {
      "id": "ex-mp-1",
      "type": "match-pairs",
      "skill": "reading",
      "prompt": "Match each word to its English meaning.",
      "pairs": [
        { "id": "p1", "left": "hier", "right": "yesterday" },
        { "id": "p2", "left": "fait", "right": "done / made" },
        { "id": "p3", "left": "vu", "right": "seen" },
        { "id": "p4", "left": "acheté", "right": "bought" }
      ]
    },
    {
      "id": "ex-ro-1",
      "type": "reorder",
      "skill": "writing",
      "prompt": "Put the words in order to say \"I ate a pizza.\"",
      "tokens": [
        { "id": "t1", "text": "J'ai" },
        { "id": "t2", "text": "mangé" },
        { "id": "t3", "text": "une" },
        { "id": "t4", "text": "pizza" }
      ],
      "correctOrder": ["t1", "t2", "t3", "t4"]
    },
    {
      "id": "ex-li-1",
      "type": "listen",
      "skill": "listening",
      "prompt": "Listen, then: what did the speaker do yesterday?",
      "audio": "audio/a1.2/unit-02-past/listen-1.mp3",
      "transcript": "Hier, j'ai visité un musée avec un ami.",
      "options": [
        { "id": "a", "text": "Visited a museum" },
        { "id": "b", "text": "Watched a film" },
        { "id": "c", "text": "Worked at home" }
      ],
      "correct": ["a"],
      "explanation": "« j'ai visité un musée » = I visited a museum."
    },
    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read about last weekend and answer both questions.",
      "passageFr": "Le week-end dernier, j'ai visité Paris. J'ai vu la tour Eiffel et j'ai mangé un croissant.",
      "passageEn": "Last weekend, I visited Paris. I saw the Eiffel Tower and I ate a croissant.",
      "questions": [
        {
          "id": "q1",
          "prompt": "Which city did they visit?",
          "options": [
            { "id": "a", "text": "Paris" },
            { "id": "b", "text": "Lyon" },
            { "id": "c", "text": "Nice" }
          ],
          "correct": ["a"]
        },
        {
          "id": "q2",
          "prompt": "What did they see?",
          "options": [
            { "id": "a", "text": "The Eiffel Tower" },
            { "id": "b", "text": "The sea" },
            { "id": "c", "text": "A film" }
          ],
          "correct": ["a"]
        }
      ]
    },
    {
      "id": "ex-fb-2",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Ask a friend (tu) if they did their homework.",
      "inputMode": "dropdown",
      "template": "Tu {{b1}} fait tes devoirs ?",
      "blanks": [{ "id": "b1", "accept": ["as"], "options": ["as", "avez"] }],
      "explanation": "tu as fait (avez is the vous form)."
    }
  ]
}
