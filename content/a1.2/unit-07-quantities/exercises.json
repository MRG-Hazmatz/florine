    {
      "id": "ex-rd-1",
      "type": "read",
      "skill": "reading",
      "prompt": "Read and answer both questions.",
      "passageFr": "Le samedi, je vais au marché. J'achète beaucoup de fruits et un peu de fromage. C'est moins cher qu'au supermarché.",
      "passageEn": "On Saturdays, I go to the market. I buy a lot of fruit and a little cheese. It's cheaper than the supermarket.",
      "questions": [
        {
          "id": "q1",
          "prompt": "When does the speaker go to the market?",
          "options": [
            {
              "id": "a",
              "text": "On Saturdays"
            },
            {
              "id": "b",
              "text": "Every morning"
            },
            {
              "id": "c",
              "text": "On Sundays"
            }
          ],
          "correct": [
            "a"
          ]
        },
        {
          "id": "q2",
          "prompt": "Compared to the supermarket, the market is…",
          "options": [
            {
              "id": "a",
              "text": "cheaper"
            },
            {
              "id": "b",
              "text": "more expensive"
            },
            {
              "id": "c",
              "text": "the same price"
            }
          ],
          "correct": [
            "a"
          ]
        }
      ]
    },
    {
