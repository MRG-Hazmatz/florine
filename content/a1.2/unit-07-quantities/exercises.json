{
  "schemaVersion": 1,
  "unitId": "a1.2/unit-07-quantities",
  "passThreshold": 0.7,
  "exercises": [
    {
      "id": "ex-mc-1",
      "type": "multiple-choice",
      "skill": "reading",
      "prompt": "What does « beaucoup de » mean?",
      "options": [
        {
          "id": "a",
          "text": "a lot of"
        },
        {
          "id": "b",
          "text": "a little of"
        },
        {
          "id": "c",
          "text": "not enough"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "beaucoup de = a lot of; un peu de = a little."
    },
    {
      "id": "ex-mc-2",
      "type": "multiple-choice",
      "skill": "writing",
      "prompt": "After a quantity word, which is correct? « Un kilo ___ pommes. »",
      "options": [
        {
          "id": "a",
          "text": "de"
        },
        {
          "id": "b",
          "text": "des"
        },
        {
          "id": "c",
          "text": "du"
        }
      ],
      "correct": [
        "a"
      ],
      "explanation": "Quantity expressions take just de — un kilo de pommes (no article)."
    },
    {
      "id": "ex-fb-1",
      "type": "fill-blank",
      "skill": "writing",
      "prompt": "Say there's A LOT of fruit at the market.",
